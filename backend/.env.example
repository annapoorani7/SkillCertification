# PostgreSQL connection URL
DATABASE_URL=postgresql://skillcert:skillcert_password@localhost:5432/skillcert_dev

# MongoDB connection URL
MONGODB_URI=mongodb://localhost:27017/skillcert

# Redis (if used)
REDIS_URL=redis://localhost:6379

# JWT secrets
JWT_SECRET=your_jwt_secret
REFRESH_TOKEN_SECRET=your_refresh_secret
VERIFICATION_TOKEN_SECRET=your_verification_secret
MFA_TOKEN_SECRET=your_mfa_secret

# Blockchain - Ganache Local (Development)
GANACHE_RPC_URL=http://127.0.0.1:8545
CONTRACT_ADDRESS=0x06775b1D279c578E6d338939D9E8204117fe1522

# Blockchain - Polygon Networks
POLYGON_MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com
POLYGON_RPC_URL=https://polygon-rpc.com

# Blockchain - BSC Networks
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-e.bnbchain.org:8545
BSC_RPC_URL=https://bsc-dataseed1.bnbchain.org

# Private key for transaction signing
# Format: 0x... (without 0x prefix if using from MetaMask export)
DEPLOYER_PRIVATE_KEY=your_deployer_private_key
PRIVATE_KEY=your_private_key

# Pinata API for IPFS
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key

# Gas reporting (for Hardhat)
REPORT_GAS=false
COINMARKETCAP_API_KEY=your_coinmarketcap_key
